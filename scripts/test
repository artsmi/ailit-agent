#!/usr/bin/env bash
# Быстрые тесты без e2e и без integration (сеть).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"
export PYTHONPATH="${REPO_ROOT}/ailit${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m pytest -m "not e2e and not integration" "$@"
