#!/usr/bin/env bash
# Установка dev-зависимостей в локальный .venv репозитория.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"
VENV="${REPO_ROOT}/.venv"
if [[ ! -d "${VENV}" ]]; then
  python3 -m venv "${VENV}"
fi
# shellcheck disable=SC1091
source "${VENV}/bin/activate"
python3 -m pip install -U pip
python3 -m pip install -e ".[dev]"
echo "Готово: venv ${VENV}. Для UI: pip install -e '.[chat]'"
