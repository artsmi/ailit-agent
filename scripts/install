#!/usr/bin/env bash
# Установка CLI ailit из корня репозитория.
#
# Режимы:
#   ./scripts/install           # prod (по умолчанию): venv в AILIT_INSTALL_PREFIX, shim в ~/.local/bin
#   ./scripts/install dev       # то же: pip install -e . + [dev,chat,tui]
#   ./scripts/install prod      # без -e: venv в AILIT_INSTALL_PREFIX, shim в ~/.local/bin
#
# Переменные:
#   AILIT_INSTALL_NO_SHIM=1     — не создавать симлинк ~/.local/bin/ailit
#   AILIT_INSTALL_PREFIX        — корень для prod venv (по умолчанию ~/.local/share/ailit)
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
MODE="${1:-prod}"
cd "${REPO_ROOT}"

LOCAL_BIN="${HOME}/.local/bin"
INSTALL_PREFIX="${AILIT_INSTALL_PREFIX:-${HOME}/.local/share/ailit}"

if [[ "${MODE}" != "dev" && "${MODE}" != "prod" ]]; then
  echo "Неизвестный режим: ${MODE}. Используйте: dev | prod" >&2
  exit 2
fi

if [[ "${MODE}" == "prod" ]]; then
  VENV="${INSTALL_PREFIX}/venv"
  mkdir -p "${INSTALL_PREFIX}"
  if [[ ! -d "${VENV}" ]]; then
    python3 -m venv "${VENV}"
  fi
  # shellcheck disable=SC1091
  source "${VENV}/bin/activate"
  python3 -m pip install -U pip setuptools wheel
  python3 -m pip install ".[chat,tui]"
  echo "Готово: production-установка в ${VENV} (без -e; префикс ${INSTALL_PREFIX})"
else
  VENV="${REPO_ROOT}/.venv"
  if [[ ! -d "${VENV}" ]]; then
    python3 -m venv "${VENV}"
  fi
  # shellcheck disable=SC1091
  source "${VENV}/bin/activate"

  python3 -m pip install -U pip setuptools wheel
  python3 -m pip install -e .
  python3 -m pip install -e '.[dev]'
  python3 -m pip install -e '.[chat]'
  python3 -m pip install -e '.[tui]'

  echo "Готово: пакет в ${VENV}"
fi

if [[ -n "${AILIT_INSTALL_NO_SHIM:-}" ]]; then
  echo "Shim пропущен (AILIT_INSTALL_NO_SHIM). Тогда: source ${VENV}/bin/activate"
else
  mkdir -p "${LOCAL_BIN}"
  if [[ -x "${VENV}/bin/ailit" ]]; then
    ln -sf "${VENV}/bin/ailit" "${LOCAL_BIN}/ailit"
    echo "Команда ailit:  ${LOCAL_BIN}/ailit  →  ${VENV}/bin/ailit"
    if [[ "${MODE}" == "dev" ]]; then
      echo "(последний успешный install перезаписывает shim; указывает на этот клон)"
    fi
    case ":${PATH}:" in
      *:"${LOCAL_BIN}":*) echo "PATH уже содержит ${LOCAL_BIN}" ;;
      *)
        echo "Добавьте в PATH (например в ~/.bashrc):"
        echo "  export PATH=\"\${HOME}/.local/bin:\${PATH}\""
        ;;
    esac
    echo "Проверка из любого каталога:  ailit --help"
  else
    echo "Предупреждение: не найден ${VENV}/bin/ailit — shim не создан."
  fi
fi

echo "Опционально (pytest из venv):  source ${VENV}/bin/activate"
