#!/usr/bin/env bash
# Очищает содержимое локальной PAG (SQLite): файл остаётся, таблицы pag_* пустые.
# Путь как у runtime: AILIT_PAG_DB_PATH или ~/.ailit/pag/store.sqlite3 (см. PagRuntimeConfig).
# При доступном systemd --user останавливает ailit.service на время очистки (снимает блокировки).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PYTHONPATH="${REPO_ROOT}/tools${PYTHONPATH:+:${PYTHONPATH}}"

cd "${REPO_ROOT}"

_have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

_systemd_user_available() {
  if ! _have_cmd systemctl; then
    return 1
  fi
  if [[ -z "${XDG_RUNTIME_DIR:-}" ]]; then
    return 1
  fi
  if [[ ! -S "${XDG_RUNTIME_DIR}/bus" ]]; then
    return 1
  fi
  return 0
}

_stop_ailit_if_needed() {
  if [[ -n "${AILIT_INSTALL_NO_SYSTEMD:-}" ]]; then
    return 0
  fi
  if ! _systemd_user_available; then
    return 0
  fi
  systemctl --user stop ailit.service 2>/dev/null || true
}

_start_ailit_if_needed() {
  if [[ -n "${AILIT_INSTALL_NO_SYSTEMD:-}" ]]; then
    return 0
  fi
  if ! _systemd_user_available; then
    return 0
  fi
  systemctl --user start ailit.service 2>/dev/null || true
}

_stop_ailit_if_needed
python3 - <<'PY'
from __future__ import annotations

import sqlite3
import sys
from pathlib import Path

from agent_core.memory.pag_runtime import PagRuntimeConfig
from agent_core.memory.sqlite_pag import SqlitePagStore

cfg = PagRuntimeConfig.from_env()
db_path: Path = cfg.db_path
db_path.parent.mkdir(parents=True, exist_ok=True)

if not db_path.exists():
    SqlitePagStore(db_path)
    print(f"PAG не было — создана пустая схема: {db_path}")
    sys.exit(0)

con = sqlite3.connect(str(db_path))
try:
    cur = con.execute(
        "SELECT name FROM sqlite_master "
        "WHERE type='table' AND name LIKE 'pag_%' ORDER BY name"
    )
    tables = [str(r[0]) for r in cur.fetchall()]
    if not tables:
        SqlitePagStore(db_path)
        print(f"В файле не было таблиц pag_* — применена схема: {db_path}")
        sys.exit(0)
    con.execute("PRAGMA foreign_keys = OFF")
    for name in tables:
        con.execute(f'DELETE FROM "{name}"')
    con.commit()
    con.execute("VACUUM")
    con.commit()
finally:
    con.close()

print(f"готово: содержимое PAG очищено, файл на месте: {db_path}")
PY
_start_ailit_if_needed
