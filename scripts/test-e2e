#!/usr/bin/env bash
# Материализация демо в .ailit/demo-mini-app (для ревью) + один e2e-файл.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"
export PYTHONPATH="${REPO_ROOT}/ailit${PYTHONPATH:+:${PYTHONPATH}}"
python3 -c \
  'from ailit_cli.demo_workspace import default_demo_app_path, materialize_demo_app; materialize_demo_app(default_demo_app_path(), overwrite=True)'
exec python3 -m pytest \
  tests/e2e/test_demo_workspace.py \
  tests/e2e/test_memory_m4_e2e.py \
  "$@"
