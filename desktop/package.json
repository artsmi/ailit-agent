{
  "name": "ailit-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n MAIN,PRELOAD,WEB,ELECTRON -c blue,magenta,green,yellow \"tsc -p tsconfig.main.json -w\" \"tsc -p tsconfig.preload.json -w\" \"vite\" \"wait-on http://127.0.0.1:5173 && env AILIT_DESKTOP_DEV_URL=http://127.0.0.1:5173 electron dist/main/main.js\"",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "rimraf dist && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "package:linux": "npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.26.4",
    "react-router-dom": "^7.0.0",
    "three": "^0.179.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "dev.ailit.desktop",
    "productName": "ailit",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
