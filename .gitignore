# Secrets and local operator state
.env
.env.*
*.key
*.pem

# Local runtime store (default contract: project-local)
.ailit/

# Локальные бинарники агента (например ripgrep для прогона 11 без системного PATH)
.local/

# Локальная тестовая конфигурация (секреты); в git — только *.example
config/test.local.yaml

# Python
build/
dist/
*.egg-info/
__pycache__/
*.py[cod]
*.pyo
.Python
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Node / Electron (desktop/)
desktop/node_modules/
desktop/.vite/
desktop/dist/
desktop/dist-app/

# Артефакты pipeline (оркестратор, субагенты) — локальные, каталог в репозитории
context/artifacts/*
!context/artifacts/.gitkeep
# Отчёты прогонов (pytest, 11_test_runner) — только локально, не коммитить
context/artifacts/reports/
